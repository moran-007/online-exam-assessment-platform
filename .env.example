NODE_ENV=development
PORT=3000
APP_NAME=online-exam-assessment-platform
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/online_exam?schema=public

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_SESSION_EXPIRES_IN=8h
JWT_REMEMBER_EXPIRES_IN=7d
JWT_IDLE_EXPIRES_IN=30m

ASSET_URL_SECRET=change_me_unique_asset_signing_secret
ASSET_URL_EXPIRES_IN=5m

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=loopback
SWAGGER_ENABLED=true
LOG_LEVEL=debug
LOG_PRETTY=true

RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_TTL_MS=600000
LOGIN_RATE_LIMIT_MAX=5
REFRESH_RATE_LIMIT_TTL_MS=600000
REFRESH_RATE_LIMIT_MAX=30

UPLOADS_DIR=uploads
BACKUP_DIR=output/backups
BACKUP_DAILY_RETENTION=14
BACKUP_WEEKLY_RETENTION=8
# BACKUP_REMOTE=s3:online-exam-backups

HYDRO_BASE_URL=https://oj.example.com
HYDRO_DEFAULT_LANGUAGES=cc.cc17o2,py.py3
# Optional direct-submit adapter for Hydro-compatible endpoints.
# Template variables: baseUrl, problemId, numericProblemId, postSubmitUrl, language, username, loginUsername, loginPassword.
# HYDRO_SUBMIT_URL_TEMPLATE={{postSubmitUrl}}
# HYDRO_SUBMIT_METHOD=POST
# HYDRO_SUBMIT_HEADERS_JSON={"Authorization":"Bearer token"}
# HYDRO_SUBMIT_BODY_TEMPLATE={"pid":"{{problemId}}","lang":"{{language}}","code":"{{code}}","username":"{{username}}"}
# HYDRO_CALLBACK_SECRET=change_me_hydro_callback_secret
