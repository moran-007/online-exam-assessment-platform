  monthlyTokenBudget Int?      @map("monthly_token_budget")
  lastTestStatus     String?   @map("last_test_status") @db.VarChar(32)
  lastTestMessage    String?   @map("last_test_message") @db.VarChar(300)
  lastTestAt         DateTime? @map("last_test_at")
  createdBy          String?   @map("created_by") @db.Uuid
  updatedBy          String?   @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  summaryTasks AiSummaryTask[]
  usageEvents  AiUsageEvent[]

  @@index([enabled, isDefault])
  @@index([provider])
  @@map("ai_provider_configs")
}

model AiUsageEvent {
  id                    String   @id @default(uuid()) @db.Uuid
  providerConfigId      String   @map("provider_config_id") @db.Uuid
  operation             String   @db.VarChar(64)
  correlationId         String   @unique @map("correlation_id") @db.VarChar(64)
  requestedOutputTokens Int      @map("requested_output_tokens")
  inputTokens           Int      @map("input_tokens")
  outputTokens          Int      @map("output_tokens")
  totalTokens           Int      @map("total_tokens")
  usageReported         Boolean  @default(false) @map("usage_reported")
  createdBy             String   @map("created_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")

  providerConfig AiProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)

  @@index([providerConfigId, createdAt])
  @@index([operation, createdAt])
  @@map("ai_usage_events")
}

model AiProviderCapability {
  id                 String   @id @default(uuid()) @db.Uuid
  provider           String   @db.VarChar(50)
  modelPattern       String   @map("model_pattern") @db.VarChar(160)
  supportsJsonObject Boolean  @default(false) @map("supports_json_object")
  supportsJsonSchema Boolean  @default(false) @map("supports_json_schema")
  supportsStreaming  Boolean  @default(false) @map("supports_streaming")
  supportsThinking   Boolean  @default(false) @map("supports_thinking")
  maxContextTokens   Int?     @map("max_context_tokens")
  maxOutputTokens    Int?     @map("max_output_tokens")
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([provider, modelPattern])
  @@index([provider, enabled])
  @@map("ai_provider_capabilities")
}

model AiSummaryPromptTemplate {
  id           String        @id @default(uuid()) @db.Uuid
  code         String        @db.VarChar(80)
  summaryType  AiSummaryType @map("summary_type")
  version      Int
  systemPrompt String        @map("system_prompt") @db.Text
  outputSchema Json          @map("output_schema")
  enabled      Boolean       @default(false)
  reviewedBy   String?       @map("reviewed_by") @db.Uuid
  changeReason String?       @map("change_reason") @db.VarChar(300)
  createdBy    String?       @map("created_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  tasks AiSummaryTask[]

  @@unique([code, version])
  @@index([summaryType, enabled])
  @@map("ai_summary_prompt_templates")
}

model AiSummaryTask {
  id               String              @id @default(uuid()) @db.Uuid
  type             AiSummaryType
  subjectId        String              @map("subject_id") @db.Uuid
  scopeJson        Json                @map("scope_json")
  inputHash        String              @map("input_hash") @db.VarChar(64)
  datasetVersion   String              @map("dataset_version") @db.VarChar(32)
  promptTemplateId String              @map("prompt_template_id") @db.Uuid
  promptVersion    Int                 @map("prompt_version")
  schemaVersion    String              @map("schema_version") @db.VarChar(32)
  providerConfigId String              @map("provider_config_id") @db.Uuid
  modelSnapshot    String              @map("model_snapshot") @db.VarChar(160)
  status           AiSummaryTaskStatus @default(PENDING)
  attemptCount     Int                 @default(0) @map("attempt_count")
  correlationId    String              @unique @map("correlation_id") @db.VarChar(64)
  inputTokens      Int                 @default(0) @map("input_tokens")
  outputTokens     Int                 @default(0) @map("output_tokens")
  estimatedCost    Decimal             @default(0) @map("estimated_cost") @db.Decimal(18, 6)
  createdBy        String              @map("created_by") @db.Uuid
  startedAt        DateTime?           @map("started_at")
  finishedAt       DateTime?           @map("finished_at")
  sanitizedError   String?             @map("sanitized_error") @db.VarChar(500)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  providerConfig AiProviderConfig        @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  promptTemplate AiSummaryPromptTemplate @relation(fields: [promptTemplateId], references: [id], onDelete: Restrict)
  summary        AiSummary?

  @@unique([type, subjectId, inputHash, datasetVersion, promptVersion, schemaVersion, providerConfigId, modelSnapshot], map: "ai_summary_tasks_idempotency_key")
  @@index([status, createdAt])
  @@index([type, subjectId, createdAt])
  @@index([createdBy, createdAt])
  @@map("ai_summary_tasks")
}

model AiSummary {
  id                 String                @id @default(uuid()) @db.Uuid
  taskId             String                @unique @map("task_id") @db.Uuid
  type               AiSummaryType
  subjectId          String                @map("subject_id") @db.Uuid
  summaryJson        Json                  @map("summary_json")
  sourceSnapshotJson Json                  @map("source_snapshot_json")
  evidenceIndexJson  Json                  @map("evidence_index_json")
  reviewStatus       AiSummaryReviewStatus @default(DRAFT) @map("review_status")
  draftVersion       Int                   @default(1) @map("draft_version")
  editedBy           String?               @map("edited_by") @db.Uuid
  reviewedBy         String?               @map("reviewed_by") @db.Uuid
  publishedAt        DateTime?             @map("published_at")
  revokedAt          DateTime?             @map("revoked_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  task AiSummaryTask @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@index([type, subjectId, createdAt])
  @@index([reviewStatus, publishedAt])
  @@map("ai_summaries")
}
