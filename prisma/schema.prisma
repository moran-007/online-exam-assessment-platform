generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  SUPER_ADMIN
  ADMIN
  TEACHER
  ASSISTANT
  STUDENT
  PARENT
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
  DELETED
}

enum RoleStatus {
  ACTIVE
  DISABLED
}

enum PermissionType {
  MENU
  BUTTON
  API
}

enum CourseStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum KnowledgePointStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum TagType {
  QUESTION
  PAPER
  EXAM
  CUSTOM
}

enum TagStatus {
  ACTIVE
  DISABLED
}

enum QuestionType {
  SINGLE_CHOICE   @map("single_choice")
  MULTIPLE_CHOICE @map("multiple_choice")
  TRUE_FALSE      @map("true_false")
  FILL_BLANK      @map("fill_blank")
  SHORT_ANSWER    @map("short_answer")
  PROGRAMMING     @map("programming")
  MATERIAL        @map("material")
  FILE_UPLOAD     @map("file_upload")
  SCRATCH_PROJECT @map("scratch_project")
  ARDUINO_PROJECT @map("arduino_project")
}

enum QuestionStatus {
  DRAFT          @map("draft")
  PENDING_REVIEW @map("pending_review")
  PUBLISHED      @map("published")
  DISABLED       @map("disabled")
  ARCHIVED       @map("archived")
}

enum ScoringEvaluationSource {
  AUTO          @map("auto")
  MANUAL        @map("manual")
  JUDGE         @map("judge")
  REGRADE       @map("regrade")
  AI_SUGGESTION @map("ai_suggestion")
}

enum ScoringEvaluationStatus {
  TRIAL      @map("trial")
  OFFICIAL   @map("official")
  SUPERSEDED @map("superseded")
}

enum RegradeRunStatus {
  PROCESSING @map("processing")
  PREVIEWED  @map("previewed")
  APPLYING   @map("applying")
  APPLIED    @map("applied")
  CANCELLED  @map("cancelled")
  FAILED     @map("failed")
  EXPIRED    @map("expired")
}

enum RegradeRuleSource {
  SNAPSHOT  @map("snapshot")
  LATEST    @map("latest")
  SPECIFIED @map("specified")
}

enum PaperType {
  FIXED    @map("fixed")
  RULE     @map("rule")
  RANDOM   @map("random")
  PRACTICE @map("practice")
}

enum PaperStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")
}

enum ExamStatus {
  DRAFT     @map("draft")
  SCHEDULED @map("scheduled")
  RUNNING   @map("running")
  ENDED     @map("ended")
  ARCHIVED  @map("archived")
}

enum ShowAnswerMode {
  NEVER          @map("never")
  AFTER_SUBMIT   @map("after_submit")
  AFTER_EXAM_END @map("after_exam_end")
  AFTER_MANUAL   @map("after_manual")
}

enum ShowScoreMode {
  NEVER          @map("never")
  AFTER_SUBMIT   @map("after_submit")
  AFTER_GRADED   @map("after_graded")
  AFTER_EXAM_END @map("after_exam_end")
  AFTER_MANUAL   @map("after_manual")
}

enum AttemptStatus {
  NOT_STARTED       @map("not_started")
  IN_PROGRESS       @map("in_progress")
  SUBMITTED         @map("submitted")
  GRADING           @map("grading")
  GRADED            @map("graded")
  CANCELLED         @map("cancelled")
  TIMEOUT_SUBMITTED @map("timeout_submitted")
}

enum AnswerRecordStatus {
  SAVED         @map("saved")
  SUBMITTED     @map("submitted")
  AUTO_GRADED   @map("auto_graded")
  MANUAL_NEEDED @map("manual_needed")
  MANUAL_GRADED @map("manual_graded")
  JUDGE_PENDING @map("judge_pending")
  JUDGE_DONE    @map("judge_done")
}

enum WrongQuestionSourceType {
  EXAM              @map("exam")
  PRACTICE          @map("practice")
  MANUAL            @map("manual")
  AI_RECOMMENDATION @map("ai_recommendation")
}

enum MasteryStatus {
  UNMASTERED @map("unmastered")
  REVIEWING  @map("reviewing")
  MASTERED   @map("mastered")
  IGNORED    @map("ignored")
}

enum ExportStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  SUCCESS    @map("success")
  FAILED     @map("failed")
  EXPIRED    @map("expired")
  CANCELED   @map("canceled")
}

enum FileVisibility {
  PUBLIC    @map("public")
  PRIVATE   @map("private")
  TEMPORARY @map("temporary")
}

enum AiSummaryType {
  EXAM          @map("exam")
  STUDENT       @map("student")
  CLASS         @map("class")
  PARENT_REPORT @map("parent_report")
  LESSON        @map("lesson")
}

enum AiSummaryTaskStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  SUCCEEDED  @map("succeeded")
  FAILED     @map("failed")
  CANCELLED  @map("cancelled")
}

enum AiSummaryReviewStatus {
  DRAFT     @map("draft")
  IN_REVIEW @map("in_review")
  APPROVED  @map("approved")
  PUBLISHED @map("published")
  REVOKED   @map("revoked")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  username     String     @unique @db.VarChar(64)
  phone        String?    @unique @db.VarChar(32)
  email        String?    @unique @db.VarChar(128)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  realName     String?    @map("real_name") @db.VarChar(64)
  avatarUrl    String?    @map("avatar_url") @db.Text
  userType     UserType   @map("user_type")
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  roles                 UserRole[]
  authAccounts          AuthAccount[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  studentClasses        ClassStudent[]         @relation("ClassStudentUser")
  teachingClasses       ClassTeacher[]         @relation("ClassTeacherUser")
  examAnnouncements     ExamAnnouncement[]     @relation("ExamAnnouncementCreator")
  examAnnouncementReads ExamAnnouncementRead[]
  wrongQuestionEvents   WrongQuestionEvent[]

  @@index([userType])
  @@index([status])
  @@map("users")
}

model AuthAccount {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  provider       String    @db.VarChar(64)
  providerUserId String    @map("provider_user_id") @db.VarChar(128)
  unionId        String?   @map("union_id") @db.VarChar(128)
  credentialJson Json?     @map("credential_json")
  linkedAt       DateTime  @default(now()) @map("linked_at")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId, provider])
  @@map("auth_accounts")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  jti            String    @unique @db.VarChar(64)
  sessionId      String    @map("session_id") @db.VarChar(64)
  tokenHash      String    @map("token_hash") @db.VarChar(128)
  rememberMe     Boolean   @default(true) @map("remember_me")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  ip             String?   @db.VarChar(64)
  userAgent      String?   @map("user_agent") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(64)
  code        String     @unique @db.VarChar(64)
  description String?    @db.Text
  status      RoleStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @db.VarChar(64)
  description String?        @db.Text
  code        String         @unique @db.VarChar(128)
  type        PermissionType
  parentId    String?        @map("parent_id") @db.Uuid
  path        String?        @db.VarChar(255)
  method      String?        @db.VarChar(16)
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  parent   Permission?      @relation("PermissionTree", fields: [parentId], references: [id])
  children Permission[]     @relation("PermissionTree")
  roles    RolePermission[]

  @@index([parentId])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  scopeType String   @default("GLOBAL") @map("scope_type") @db.VarChar(32)
  scopeId   String?  @map("scope_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Course {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(128)
  code        String       @unique @db.VarChar(64)
  description String?      @db.Text
  coverUrl    String?      @map("cover_url") @db.Text
  status      CourseStatus @default(ACTIVE)
  sortOrder   Int          @default(0) @map("sort_order")
  createdBy   String?      @map("created_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  knowledgePoints KnowledgePoint[]
  questions       Question[]
  papers          Paper[]
  exams           Exam[]
  classes         ClassGroup[]

  @@index([status])
  @@map("courses")
}

model ClassGroup {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(128)
  code        String    @unique @db.VarChar(64)
  courseId    String?   @map("course_id") @db.Uuid
  description String?   @db.Text
  status      String    @default("active") @db.VarChar(32)
  sortOrder   Int       @default(0) @map("sort_order")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  course   Course?        @relation(fields: [courseId], references: [id])
  students ClassStudent[]
  teachers ClassTeacher[]

  @@index([courseId])
  @@index([status])
  @@index([sortOrder])
  @@map("classes")
}

model ClassStudent {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at")

  classGroup ClassGroup @relation(fields: [classId], references: [id])
  student    User       @relation("ClassStudentUser", fields: [studentId], references: [id])

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
  @@map("class_students")
}

model ClassTeacher {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at")

  classGroup ClassGroup @relation(fields: [classId], references: [id])
  teacher    User       @relation("ClassTeacherUser", fields: [teacherId], references: [id])

  @@unique([classId, teacherId])
  @@index([classId])
  @@index([teacherId])
  @@map("class_teachers")
}

model KnowledgePoint {
  id        String               @id @default(uuid()) @db.Uuid
  courseId  String               @map("course_id") @db.Uuid
  parentId  String?              @map("parent_id") @db.Uuid
  name      String               @db.VarChar(128)
  code      String               @db.VarChar(64)
  level     Int                  @default(1)
  sortOrder Int                  @default(0) @map("sort_order")
  status    KnowledgePointStatus @default(ACTIVE)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  deletedAt DateTime?            @map("deleted_at")

  course    Course                   @relation(fields: [courseId], references: [id])
  parent    KnowledgePoint?          @relation("KnowledgePointTree", fields: [parentId], references: [id])
  children  KnowledgePoint[]         @relation("KnowledgePointTree")
  questions QuestionKnowledgePoint[]

  @@unique([courseId, code])
  @@index([courseId])
  @@index([parentId])
  @@map("knowledge_points")
}

model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(64)
  code      String    @unique @db.VarChar(64)
  type      TagType   @default(QUESTION)
  status    TagStatus @default(ACTIVE)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  questions QuestionTag[]

  @@index([type])
  @@map("tags")
}

model Question {
  id                 String         @id @default(uuid()) @db.Uuid
  courseId           String         @map("course_id") @db.Uuid
  type               QuestionType
  title              String         @db.VarChar(255)
  content            String         @db.Text
  difficulty         Int
  defaultScore       Decimal        @map("default_score") @db.Decimal(8, 2)
  analysis           String?        @db.Text
  status             QuestionStatus @default(DRAFT)
  version            Int            @default(1)
  allowOptionShuffle Boolean        @default(true) @map("allow_option_shuffle")
  createdBy          String?        @map("created_by") @db.Uuid
  updatedBy          String?        @map("updated_by") @db.Uuid
  reviewedBy         String?        @map("reviewed_by") @db.Uuid
  reviewedAt         DateTime?      @map("reviewed_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")

  course              Course                   @relation(fields: [courseId], references: [id])
  options             QuestionOption[]
  answer              QuestionAnswer?
  knowledgePoints     QuestionKnowledgePoint[]
  tags                QuestionTag[]
  versions            QuestionVersion[]
  paperQuestions      PaperQuestion[]
  answerRecords       AnswerRecord[]
  wrongQuestions      WrongQuestion[]
  wrongQuestionEvents WrongQuestionEvent[]
  programmingRef      ProgrammingProblemRef?
  judgeSubmissions    JudgeSubmission[]
  compositionChildren QuestionComposition[]    @relation("CompositionParent")
  compositionParents  QuestionComposition[]    @relation("CompositionChild")
  scoringRuleVersions ScoringRuleVersion[]

  @@index([courseId])
  @@index([type])
  @@index([difficulty])
  @@index([status])
  @@index([createdBy])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  optionKey  String   @map("option_key") @db.VarChar(16)
  content    String   @db.Text
  isCorrect  Boolean  @default(false) @map("is_correct")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  question Question @relation(fields: [questionId], references: [id])

  @@unique([questionId, optionKey])
  @@index([questionId])
  @@map("question_options")
}

model QuestionAnswer {
  id                   String   @id @default(uuid()) @db.Uuid
  questionId           String   @unique @map("question_id") @db.Uuid
  currentRuleVersionId String?  @unique @map("current_rule_version_id") @db.Uuid
  answerJson           Json     @map("answer_json")
  scoringRuleJson      Json?    @map("scoring_rule_json")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  question           Question            @relation(fields: [questionId], references: [id])
  currentRuleVersion ScoringRuleVersion? @relation("CurrentScoringRule", fields: [currentRuleVersionId], references: [id])

  @@map("question_answers")
}

model QuestionKnowledgePoint {
  id               String   @id @default(uuid()) @db.Uuid
  questionId       String   @map("question_id") @db.Uuid
  knowledgePointId String   @map("knowledge_point_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  question       Question       @relation(fields: [questionId], references: [id])
  knowledgePoint KnowledgePoint @relation(fields: [knowledgePointId], references: [id])

  @@unique([questionId, knowledgePointId])
  @@index([questionId])
  @@index([knowledgePointId])
  @@map("question_knowledge_points")
}

model QuestionTag {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [id])
  tag      Tag      @relation(fields: [tagId], references: [id])

  @@unique([questionId, tagId])
  @@index([questionId])
  @@index([tagId])
  @@map("question_tags")
}

model QuestionVersion {
  id           String   @id @default(uuid()) @db.Uuid
  questionId   String   @map("question_id") @db.Uuid
  version      Int
  snapshotJson Json     @map("snapshot_json")
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [id])

  @@unique([questionId, version])
  @@index([questionId])
  @@map("question_versions")
}

model QuestionComposition {
  id               String   @id @default(uuid()) @db.Uuid
  parentQuestionId String   @map("parent_question_id") @db.Uuid
  childQuestionId  String   @map("child_question_id") @db.Uuid
  score            Decimal  @db.Decimal(8, 2)
  sortOrder        Int      @default(0) @map("sort_order")
  configJson       Json?    @map("config_json")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  parentQuestion Question @relation("CompositionParent", fields: [parentQuestionId], references: [id], onDelete: Restrict)
  childQuestion  Question @relation("CompositionChild", fields: [childQuestionId], references: [id], onDelete: Restrict)

  @@unique([parentQuestionId, childQuestionId])
  @@index([parentQuestionId, sortOrder])
  @@index([childQuestionId])
  @@map("question_compositions")
}

model ScoringRuleVersion {
  id             String   @id @default(uuid()) @db.Uuid
  questionId     String   @map("question_id") @db.Uuid
  version        Int
  adapterKey     String   @map("adapter_key") @db.VarChar(64)
  adapterVersion Int      @default(1) @map("adapter_version")
  answerJson     Json     @map("answer_json")
  ruleJson       Json?    @map("rule_json")
  rubricJson     Json?    @map("rubric_json")
  checksum       String   @db.VarChar(64)
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  question    Question            @relation(fields: [questionId], references: [id], onDelete: Restrict)
  currentFor  QuestionAnswer?     @relation("CurrentScoringRule")
  evaluations ScoringEvaluation[]

  @@unique([questionId, version])
  @@index([questionId, createdAt])
  @@map("scoring_rule_versions")
}

model Paper {
  id               String      @id @default(uuid()) @db.Uuid
  name             String      @db.VarChar(128)
  courseId         String      @map("course_id") @db.Uuid
  totalScore       Decimal     @default(0) @map("total_score") @db.Decimal(8, 2)
  durationMinutes  Int         @default(60) @map("duration_minutes")
  type             PaperType   @default(FIXED)
  status           PaperStatus @default(DRAFT)
  shuffleQuestions Boolean     @default(false) @map("shuffle_questions")
  shuffleOptions   Boolean     @default(false) @map("shuffle_options")
  createdBy        String?     @map("created_by") @db.Uuid
  updatedBy        String?     @map("updated_by") @db.Uuid
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")

  course    Course          @relation(fields: [courseId], references: [id])
  sections  PaperSection[]
  questions PaperQuestion[]
  rules     PaperRule[]
  exams     Exam[]

  @@index([courseId])
  @@index([type])
  @@index([status])
  @@index([createdBy])
  @@map("papers")
}

model PaperSection {
  id               String   @id @default(uuid()) @db.Uuid
  paperId          String   @map("paper_id") @db.Uuid
  title            String   @db.VarChar(128)
  description      String?  @db.Text
  sortOrder        Int      @default(0) @map("sort_order")
  score            Decimal  @default(0) @db.Decimal(8, 2)
  shuffleQuestions Boolean  @default(false) @map("shuffle_questions")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  paper     Paper           @relation(fields: [paperId], references: [id])
  questions PaperQuestion[]

  @@index([paperId])
  @@map("paper_sections")
}

model PaperQuestion {
  id                   String   @id @default(uuid()) @db.Uuid
  paperId              String   @map("paper_id") @db.Uuid
  sectionId            String?  @map("section_id") @db.Uuid
  questionId           String   @map("question_id") @db.Uuid
  questionSnapshotJson Json     @map("question_snapshot_json")
  score                Decimal  @db.Decimal(8, 2)
  sortOrder            Int      @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  paper    Paper         @relation(fields: [paperId], references: [id])
  section  PaperSection? @relation(fields: [sectionId], references: [id])
  question Question      @relation(fields: [questionId], references: [id])

  @@index([paperId])
  @@index([sectionId])
  @@index([questionId])
  @@map("paper_questions")
}

model PaperRule {
  id        String   @id @default(uuid()) @db.Uuid
  paperId   String   @map("paper_id") @db.Uuid
  ruleJson  Json     @map("rule_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  paper Paper @relation(fields: [paperId], references: [id])

  @@index([paperId])
  @@map("paper_rules")
}

model Exam {
  id                  String         @id @default(uuid()) @db.Uuid
  paperId             String         @map("paper_id") @db.Uuid
  name                String         @db.VarChar(128)
  courseId            String         @map("course_id") @db.Uuid
  classId             String?        @map("class_id") @db.Uuid
  startTime           DateTime       @map("start_time")
  endTime             DateTime       @map("end_time")
  durationMinutes     Int            @map("duration_minutes")
  attemptLimit        Int            @default(1) @map("attempt_limit")
  showAnswerMode      ShowAnswerMode @default(AFTER_EXAM_END) @map("show_answer_mode")
