model AiProviderConfig {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String                @db.VarChar(100)
  provider             String                @db.VarChar(50)
  baseUrl              String                @map("base_url") @db.Text
  model                String                @db.VarChar(160)
  scope                AiProviderConfigScope @default(SYSTEM)
  ownerUserId          String?               @map("owner_user_id") @db.Uuid
  apiKeyCiphertext     String                @map("api_key_ciphertext") @db.Text
  apiKeyIv             String                @map("api_key_iv") @db.VarChar(64)
  apiKeyAuthTag        String                @map("api_key_auth_tag") @db.VarChar(64)
  apiKeyKeyVersion     Int                   @map("api_key_key_version")
  enabled              Boolean               @default(true)
  isDefault            Boolean               @default(false) @map("is_default")
  timeoutMs            Int                   @default(30000) @map("timeout_ms")
  maxTokens            Int?                  @map("max_tokens")
  monthlyTokenBudget   Int?                  @map("monthly_token_budget")
  inputCostPerMillion  Decimal               @default(0) @map("input_cost_per_million") @db.Decimal(12, 4)
  outputCostPerMillion Decimal               @default(0) @map("output_cost_per_million") @db.Decimal(12, 4)
  lastTestStatus       String?               @map("last_test_status") @db.VarChar(32)
  lastTestMessage      String?               @map("last_test_message") @db.VarChar(300)
  lastTestAt           DateTime?             @map("last_test_at")
  createdBy            String?               @map("created_by") @db.Uuid
  updatedBy            String?               @map("updated_by") @db.Uuid
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  summaryTasks   AiSummaryTask[]
  usageEvents    AiUsageEvent[]
  regressionRuns AiModelRegressionRun[]
  owner          User?                  @relation("PersonalAiProviderConfigOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@index([enabled, isDefault])
  @@index([provider])
  @@index([scope, ownerUserId, enabled])
  @@map("ai_provider_configs")
}

model AiUsageEvent {
