model AiSummaryTask {
  id                      String              @id @default(uuid()) @db.Uuid
  type                    AiSummaryType
  subjectId               String              @map("subject_id") @db.Uuid
  scopeJson               Json                @map("scope_json")
  inputSnapshotJson       Json                @map("input_snapshot_json")
  inputHash               String              @map("input_hash") @db.VarChar(64)
  datasetVersion          String              @map("dataset_version") @db.VarChar(32)
  promptTemplateId        String              @map("prompt_template_id") @db.Uuid
  promptVersion           Int                 @map("prompt_version")
  schemaVersion           String              @map("schema_version") @db.VarChar(32)
  providerConfigId        String              @map("provider_config_id") @db.Uuid
  modelSnapshot           String              @map("model_snapshot") @db.VarChar(160)
  generationKey           String              @default("initial") @map("generation_key") @db.VarChar(64)
  requestedOutputTokens   Int?                @map("requested_output_tokens")
  reservationOutputTokens Int                 @map("reservation_output_tokens")
  outputLimitKey          Int                 @default(0) @map("output_limit_key")
  status                  AiSummaryTaskStatus @default(PENDING)
  attemptCount            Int                 @default(0) @map("attempt_count")
  correlationId           String              @unique @map("correlation_id") @db.VarChar(64)
  inputTokens             Int                 @default(0) @map("input_tokens")
  outputTokens            Int                 @default(0) @map("output_tokens")
  estimatedCost           Decimal             @default(0) @map("estimated_cost") @db.Decimal(18, 6)
  createdBy               String              @map("created_by") @db.Uuid
  startedAt               DateTime?           @map("started_at")
  finishedAt              DateTime?           @map("finished_at")
  sanitizedError          String?             @map("sanitized_error") @db.VarChar(500)
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  providerConfig AiProviderConfig        @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  promptTemplate AiSummaryPromptTemplate @relation(fields: [promptTemplateId], references: [id], onDelete: Restrict)
  summary        AiSummary?
  cacheEvents    AiSummaryCacheEvent[]

  @@unique([type, subjectId, inputHash, datasetVersion, promptVersion, schemaVersion, providerConfigId, modelSnapshot, generationKey, outputLimitKey], map: "ai_summary_tasks_idempotency_key")
  @@index([status, createdAt])
  @@index([type, subjectId, createdAt])
  @@index([createdBy, createdAt])
  @@map("ai_summary_tasks")
}

model AiSummary {
  id                 String                @id @default(uuid()) @db.Uuid
  taskId             String                @unique @map("task_id") @db.Uuid
  type               AiSummaryType
  subjectId          String                @map("subject_id") @db.Uuid
  summaryJson        Json                  @map("summary_json")
  sourceSnapshotJson Json                  @map("source_snapshot_json")
  evidenceIndexJson  Json                  @map("evidence_index_json")
  reviewStatus       AiSummaryReviewStatus @default(DRAFT) @map("review_status")
  draftVersion       Int                   @default(1) @map("draft_version")
  editedBy           String?               @map("edited_by") @db.Uuid
  reviewedBy         String?               @map("reviewed_by") @db.Uuid
  publishedAt        DateTime?             @map("published_at")
  revokedAt          DateTime?             @map("revoked_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  task     AiSummaryTask       @relation(fields: [taskId], references: [id], onDelete: Restrict)
  feedback AiSummaryFeedback[]

  @@index([type, subjectId, createdAt])
  @@index([reviewStatus, publishedAt])
  @@map("ai_summaries")
}

model AiSummaryCacheEvent {
  id          String        @id @default(uuid()) @db.Uuid
  taskId      String        @map("task_id") @db.Uuid
  type        AiSummaryType
  cacheHit    Boolean       @map("cache_hit")
  requestedBy String        @map("requested_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  task AiSummaryTask @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@index([type, createdAt])
  @@index([taskId, createdAt])
  @@map("ai_summary_cache_events")
}

model AiSummaryFeedback {
  id             String            @id @default(uuid()) @db.Uuid
  summaryId      String            @map("summary_id") @db.Uuid
  reportedBy     String            @map("reported_by") @db.Uuid
  verdict        AiFeedbackVerdict
  rating         Int
  evidenceRef    String?           @map("evidence_ref") @db.VarChar(160)
  comment        String?           @db.Text
  correctionText String?           @map("correction_text") @db.Text
  status         AiFeedbackStatus  @default(OPEN)
  resolutionNote String?           @map("resolution_note") @db.Text
  resolvedBy     String?           @map("resolved_by") @db.Uuid
  resolvedAt     DateTime?         @map("resolved_at") @db.Timestamptz(3)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  summary AiSummary @relation(fields: [summaryId], references: [id], onDelete: Restrict)

  @@index([summaryId, status])
  @@index([status, createdAt])
  @@index([reportedBy, createdAt])
  @@map("ai_summary_feedback")
}

model AiModelRegressionRun {
  id               String             @id @default(uuid()) @db.Uuid
  providerConfigId String             @map("provider_config_id") @db.Uuid
  promptTemplateId String             @map("prompt_template_id") @db.Uuid
  summaryType      AiSummaryType      @map("summary_type")
  status           AiRegressionStatus @default(RUNNING)
  passedCases      Int                @default(0) @map("passed_cases")
  totalCases       Int                @default(0) @map("total_cases")
  inputTokens      Int                @default(0) @map("input_tokens")
  outputTokens     Int                @default(0) @map("output_tokens")
  sanitizedError   String?            @map("sanitized_error") @db.VarChar(500)
  createdBy        String             @map("created_by") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  finishedAt       DateTime?          @map("finished_at") @db.Timestamptz(3)

  providerConfig AiProviderConfig        @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  promptTemplate AiSummaryPromptTemplate @relation(fields: [promptTemplateId], references: [id], onDelete: Restrict)

  @@index([summaryType, createdAt])
  @@index([providerConfigId, createdAt])
  @@map("ai_model_regression_runs")
}
