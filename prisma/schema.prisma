generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  SUPER_ADMIN
  ADMIN
  TEACHER
  ASSISTANT
  STUDENT
  PARENT
}

enum UserStatus {
  PENDING_ACTIVATION
  ACTIVE
  DISABLED
  LOCKED
  DELETED
}

enum ClassMemberStatus {
  ACTIVE
  LEFT
}

enum ClassTeacherRole {
  LEAD
  INSTRUCTOR
  ASSISTANT
}

enum MigrationRunStatus {
  PREFLIGHT_BLOCKED
  READY
  APPROVED
  APPLYING
  COMPLETED
  FAILED
}

enum MigrationConflictStatus {
  OPEN
  RESOLVED
  WAIVED
}

enum RoleStatus {
  ACTIVE
  DISABLED
}

enum PermissionType {
  MENU
  BUTTON
  API
}

enum CourseStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum KnowledgePointStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum TagType {
  QUESTION
  PAPER
  EXAM
  CUSTOM
}

enum TagStatus {
  ACTIVE
  DISABLED
}

enum QuestionType {
  SINGLE_CHOICE   @map("single_choice")
  MULTIPLE_CHOICE @map("multiple_choice")
  TRUE_FALSE      @map("true_false")
  FILL_BLANK      @map("fill_blank")
  SHORT_ANSWER    @map("short_answer")
  PROGRAMMING     @map("programming")
  MATERIAL        @map("material")
  FILE_UPLOAD     @map("file_upload")
  SCRATCH_PROJECT @map("scratch_project")
  ARDUINO_PROJECT @map("arduino_project")
}

enum QuestionStatus {
  DRAFT          @map("draft")
  PENDING_REVIEW @map("pending_review")
  PUBLISHED      @map("published")
  DISABLED       @map("disabled")
  ARCHIVED       @map("archived")
}

enum ScoringEvaluationSource {
  AUTO          @map("auto")
  MANUAL        @map("manual")
  JUDGE         @map("judge")
  REGRADE       @map("regrade")
  AI_SUGGESTION @map("ai_suggestion")
}

enum ScoringEvaluationStatus {
  TRIAL      @map("trial")
  OFFICIAL   @map("official")
  SUPERSEDED @map("superseded")
}

enum RegradeRunStatus {
  PROCESSING @map("processing")
  PREVIEWED  @map("previewed")
  APPLYING   @map("applying")
  APPLIED    @map("applied")
  CANCELLED  @map("cancelled")
  FAILED     @map("failed")
  EXPIRED    @map("expired")
}

enum RegradeRuleSource {
  SNAPSHOT  @map("snapshot")
  LATEST    @map("latest")
  SPECIFIED @map("specified")
}

enum PaperType {
  FIXED    @map("fixed")
  RULE     @map("rule")
  RANDOM   @map("random")
  PRACTICE @map("practice")
}

enum PaperStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")
}

enum ExamStatus {
  DRAFT     @map("draft")
  SCHEDULED @map("scheduled")
  RUNNING   @map("running")
  ENDED     @map("ended")
  ARCHIVED  @map("archived")
}

enum ShowAnswerMode {
  NEVER          @map("never")
  AFTER_SUBMIT   @map("after_submit")
  AFTER_EXAM_END @map("after_exam_end")
  AFTER_MANUAL   @map("after_manual")
}

enum ShowScoreMode {
  NEVER          @map("never")
  AFTER_SUBMIT   @map("after_submit")
  AFTER_GRADED   @map("after_graded")
  AFTER_EXAM_END @map("after_exam_end")
  AFTER_MANUAL   @map("after_manual")
}

enum AttemptStatus {
  NOT_STARTED       @map("not_started")
  IN_PROGRESS       @map("in_progress")
  SUBMITTED         @map("submitted")
  GRADING           @map("grading")
  GRADED            @map("graded")
  CANCELLED         @map("cancelled")
  TIMEOUT_SUBMITTED @map("timeout_submitted")
}

enum AnswerRecordStatus {
  SAVED         @map("saved")
  SUBMITTED     @map("submitted")
  AUTO_GRADED   @map("auto_graded")
  MANUAL_NEEDED @map("manual_needed")
  MANUAL_GRADED @map("manual_graded")
  JUDGE_PENDING @map("judge_pending")
  JUDGE_DONE    @map("judge_done")
}

enum WrongQuestionSourceType {
  EXAM              @map("exam")
  PRACTICE          @map("practice")
  MANUAL            @map("manual")
  AI_RECOMMENDATION @map("ai_recommendation")
}

enum MasteryStatus {
  UNMASTERED @map("unmastered")
  REVIEWING  @map("reviewing")
  MASTERED   @map("mastered")
  IGNORED    @map("ignored")
}

enum ExportStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  SUCCESS    @map("success")
  FAILED     @map("failed")
  EXPIRED    @map("expired")
  CANCELED   @map("canceled")
}

enum FileVisibility {
  PUBLIC    @map("public")
  PRIVATE   @map("private")
  TEMPORARY @map("temporary")
}

enum AiSummaryType {
  EXAM          @map("exam")
  STUDENT       @map("student")
  CLASS         @map("class")
  PARENT_REPORT @map("parent_report")
  LESSON        @map("lesson")
}

enum AiSummaryTaskStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  SUCCEEDED  @map("succeeded")
  FAILED     @map("failed")
  CANCELLED  @map("cancelled")
}

enum AiSummaryReviewStatus {
  DRAFT     @map("draft")
  IN_REVIEW @map("in_review")
  APPROVED  @map("approved")
  PUBLISHED @map("published")
  REVOKED   @map("revoked")
}

enum AiFeedbackVerdict {
  HELPFUL   @map("helpful")
  PARTIAL   @map("partial")
  INCORRECT @map("incorrect")
}

enum AiFeedbackStatus {
  OPEN      @map("open")
  RESOLVED  @map("resolved")
  DISMISSED @map("dismissed")
}

enum AiRegressionStatus {
  RUNNING @map("running")
  PASSED  @map("passed")
  FAILED  @map("failed")
}

enum AiProviderConfigScope {
  SYSTEM   @map("system")
  PERSONAL @map("personal")
}

enum CourseUnitStatus {
  ACTIVE   @map("active")
  DISABLED @map("disabled")
  ARCHIVED @map("archived")
}

enum ScheduleRuleStatus {
  ACTIVE   @map("active")
  PAUSED   @map("paused")
  ARCHIVED @map("archived")
}

enum LessonSessionStatus {
  PLANNED     @map("planned")
  COMPLETED   @map("completed")
  CANCELLED   @map("cancelled")
  RESCHEDULED @map("rescheduled")
}

enum LessonSessionKind {
  REGULAR   @map("regular")
  TEMPORARY @map("temporary")
  MAKEUP    @map("makeup")
  TRIAL     @map("trial")
}

enum AttendanceStatus {
  UNCONFIRMED @map("unconfirmed")
  PRESENT     @map("present")
  LATE        @map("late")
  EARLY_LEAVE @map("early_leave")
  LEAVE       @map("leave")
  ABSENT      @map("absent")
  MAKEUP      @map("makeup")
}

enum LessonHourLedgerType {
  OPENING_BALANCE   @map("opening_balance")
  PURCHASE          @map("purchase")
  GIFT              @map("gift")
  CONSUME           @map("consume")
  REVERSAL          @map("reversal")
  REFUND            @map("refund")
  TRANSFER_IN       @map("transfer_in")
  TRANSFER_OUT      @map("transfer_out")
  MANUAL_ADJUSTMENT @map("manual_adjustment")
}

enum LessonRecordStatus {
  DRAFT     @map("draft")
  SUBMITTED @map("submitted")
  PUBLISHED @map("published")
}

enum LessonRecordVersionAction {
  SAVE_DRAFT   @map("save_draft")
  SUBMIT       @map("submit")
  PUBLISH      @map("publish")
  ASSET_ADD    @map("asset_add")
  ASSET_REMOVE @map("asset_remove")
  IMPORT       @map("import")
}

enum LessonAssetAudience {
  INTERNAL @map("internal")
  LEARNER  @map("learner")
}

enum ScratchTemplateStatus {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
}

enum ScratchAssignmentStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")
}

enum ScratchWorkStatus {
  DRAFT     @map("draft")
  SUBMITTED @map("submitted")
  REVIEWED  @map("reviewed")
}

enum ScratchWorkVersionSource {
  TEMPLATE_COPY @map("template_copy")
  STUDENT_SAVE  @map("student_save")
  SUBMISSION    @map("submission")
  IMPORT        @map("import")
}

enum ScratchJudgeMode {
  NONE     @map("none")
  MANUAL   @map("manual")
  EXTERNAL @map("external")
}

enum ScratchJudgeRunStatus {
  PENDING         @map("pending")
  PROCESSING      @map("processing")
  RETRY           @map("retry")
  AWAITING_REVIEW @map("awaiting_review")
  SUCCEEDED       @map("succeeded")
  FAILED          @map("failed")
  CANCELLED       @map("cancelled")
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  username           String     @unique @db.VarChar(64)
  phone              String?    @unique @db.VarChar(32)
  email              String?    @unique @db.VarChar(128)
  passwordHash       String     @map("password_hash") @db.VarChar(255)
  realName           String?    @map("real_name") @db.VarChar(64)
  avatarUrl          String?    @map("avatar_url") @db.Text
  userType           UserType   @map("user_type")
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  activatedAt        DateTime?  @map("activated_at")
  lastLoginAt        DateTime?  @map("last_login_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")

  roles                 UserRole[]
  authAccounts          AuthAccount[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  studentClasses        ClassStudent[]         @relation("ClassStudentUser")
  teachingClasses       ClassTeacher[]         @relation("ClassTeacherUser")
  examAnnouncements     ExamAnnouncement[]     @relation("ExamAnnouncementCreator")
  examAnnouncementReads ExamAnnouncementRead[]
  wrongQuestionEvents   WrongQuestionEvent[]
  personalAiConfigs     AiProviderConfig[]     @relation("PersonalAiProviderConfigOwner")
  studentProfile        StudentProfile?
  teacherProfile        TeacherProfile?
  parentStudents        ParentStudent[]        @relation("ParentStudentParent")
  childParents          ParentStudent[]        @relation("ParentStudentStudent")
  scheduleRulesTaught   ClassScheduleRule[]    @relation("ScheduleRuleTeacher")
  lessonSessionsTaught  LessonSession[]        @relation("LessonSessionTeacher")
  attendanceRecords     AttendanceRecord[]     @relation("AttendanceStudent")
  attendanceConfirmed   AttendanceRecord[]     @relation("AttendanceConfirmer")
  attendanceRevisions   AttendanceRevision[]   @relation("AttendanceCorrector")
  lessonHourEntries     LessonHourLedger[]     @relation("LessonHourStudent")
  scratchWorks          ScratchWork[]          @relation("ScratchWorkStudent")
  scratchReviews        ScratchReview[]        @relation("ScratchReviewReviewer")

  @@index([userType])
  @@index([status])
  @@map("users")
}

model AuthAccount {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  provider       String    @db.VarChar(64)
  providerUserId String    @map("provider_user_id") @db.VarChar(128)
  unionId        String?   @map("union_id") @db.VarChar(128)
  credentialJson Json?     @map("credential_json")
  linkedAt       DateTime  @default(now()) @map("linked_at")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId, provider])
  @@map("auth_accounts")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  jti            String    @unique @db.VarChar(64)
  sessionId      String    @map("session_id") @db.VarChar(64)
  tokenHash      String    @map("token_hash") @db.VarChar(128)
  rememberMe     Boolean   @default(true) @map("remember_me")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  ip             String?   @db.VarChar(64)
  userAgent      String?   @map("user_agent") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(64)
  code        String     @unique @db.VarChar(64)
  description String?    @db.Text
  status      RoleStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @db.VarChar(64)
  description String?        @db.Text
  code        String         @unique @db.VarChar(128)
  type        PermissionType
  parentId    String?        @map("parent_id") @db.Uuid
  path        String?        @db.VarChar(255)
  method      String?        @db.VarChar(16)
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  parent   Permission?      @relation("PermissionTree", fields: [parentId], references: [id])
  children Permission[]     @relation("PermissionTree")
  roles    RolePermission[]

  @@index([parentId])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  scopeType String   @default("GLOBAL") @map("scope_type") @db.VarChar(32)
  scopeId   String?  @map("scope_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Course {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(128)
  code        String       @unique @db.VarChar(64)
  description String?      @db.Text
  coverUrl    String?      @map("cover_url") @db.Text
  status      CourseStatus @default(ACTIVE)
  sortOrder   Int          @default(0) @map("sort_order")
  createdBy   String?      @map("created_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  knowledgePoints   KnowledgePoint[]
  questions         Question[]
  papers            Paper[]
  exams             Exam[]
  classes           ClassGroup[]
  unitTemplates     CourseUnitTemplate[]
  lessonHourEntries LessonHourLedger[]

  @@index([status])
  @@map("courses")
}

model ClassGroup {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(128)
  code        String    @unique @db.VarChar(64)
  courseId    String?   @map("course_id") @db.Uuid
  description String?   @db.Text
  status      String    @default("active") @db.VarChar(32)
  sortOrder   Int       @default(0) @map("sort_order")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  course            Course?             @relation(fields: [courseId], references: [id])
  students          ClassStudent[]
  teachers          ClassTeacher[]
  scheduleRules     ClassScheduleRule[]
  lessonSessions    LessonSession[]
  lessonHourEntries LessonHourLedger[]

  @@index([courseId])
  @@index([status])
  @@index([sortOrder])
  @@map("classes")
}

model ClassStudent {
  id           String            @id @default(uuid()) @db.Uuid
  classId      String            @map("class_id") @db.Uuid
  studentId    String            @map("student_id") @db.Uuid
  status       ClassMemberStatus @default(ACTIVE)
  joinedAt     DateTime          @default(now()) @map("joined_at")
  leftAt       DateTime?         @map("left_at")
  sourceSystem String?           @map("source_system") @db.VarChar(64)
  updatedAt    DateTime          @updatedAt @map("updated_at")

  classGroup ClassGroup @relation(fields: [classId], references: [id])
  student    User       @relation("ClassStudentUser", fields: [studentId], references: [id])

  @@unique([classId, studentId])
  @@index([classId, status])
  @@index([studentId, status])
  @@map("class_students")
}

model ClassTeacher {
  id           String            @id @default(uuid()) @db.Uuid
  classId      String            @map("class_id") @db.Uuid
  teacherId    String            @map("teacher_id") @db.Uuid
  role         ClassTeacherRole  @default(INSTRUCTOR)
  status       ClassMemberStatus @default(ACTIVE)
  joinedAt     DateTime          @default(now()) @map("joined_at")
  leftAt       DateTime?         @map("left_at")
  sourceSystem String?           @map("source_system") @db.VarChar(64)
  updatedAt    DateTime          @updatedAt @map("updated_at")

  classGroup ClassGroup @relation(fields: [classId], references: [id])
  teacher    User       @relation("ClassTeacherUser", fields: [teacherId], references: [id])

  @@unique([classId, teacherId])
  @@index([classId, status])
  @@index([teacherId, status])
  @@map("class_teachers")
}

model StudentProfile {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  studentNo        String?   @unique @map("student_no") @db.VarChar(64)
  gender           String?   @db.VarChar(16)
  birthDate        DateTime? @map("birth_date") @db.Date
  school           String?   @db.VarChar(128)
  grade            String?   @db.VarChar(64)
  enrollmentStatus String    @default("active") @map("enrollment_status") @db.VarChar(32)
  enrolledAt       DateTime? @map("enrolled_at") @db.Date
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enrollmentStatus])
  @@map("student_profiles")
}

model TeacherProfile {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  employeeNo       String?   @unique @map("employee_no") @db.VarChar(64)
  subject          String?   @db.VarChar(128)
  employmentStatus String    @default("active") @map("employment_status") @db.VarChar(32)
  joinedAt         DateTime? @map("joined_at") @db.Date
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([employmentStatus])
  @@map("teacher_profiles")
}

model ParentStudent {
  id           String            @id @default(uuid()) @db.Uuid
  parentId     String            @map("parent_id") @db.Uuid
  studentId    String            @map("student_id") @db.Uuid
  relationship String            @db.VarChar(32)
  isPrimary    Boolean           @default(false) @map("is_primary")
  status       ClassMemberStatus @default(ACTIVE)
  linkedAt     DateTime          @default(now()) @map("linked_at")
  unlinkedAt   DateTime?         @map("unlinked_at")
  createdBy    String?           @map("created_by") @db.Uuid
  updatedBy    String?           @map("updated_by") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  parent  User @relation("ParentStudentParent", fields: [parentId], references: [id])
  student User @relation("ParentStudentStudent", fields: [studentId], references: [id])

  @@unique([parentId, studentId])
  @@index([parentId, status])
  @@index([studentId, status])
  @@map("parent_students")
}

model LessonType {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @unique @db.VarChar(96)
  defaultHours      Decimal  @default(1) @map("default_hours") @db.Decimal(8, 2)
  countInStatistics Boolean  @default(true) @map("count_in_statistics")
  active            Boolean  @default(true)
  description       String?  @db.Text
  createdBy         String?  @map("created_by") @db.Uuid
  updatedBy         String?  @map("updated_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  unitTemplates  CourseUnitTemplate[]
  scheduleRules  ClassScheduleRule[]
  lessonSessions LessonSession[]

  @@index([active, name])
  @@map("lesson_types")
}

model CourseUnitTemplate {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique @db.VarChar(128)
  courseId        String?          @map("course_id") @db.Uuid
  legacyUnscoped  Boolean          @default(false) @map("legacy_unscoped")
  lessonTypeId    String           @map("lesson_type_id") @db.Uuid
  category        String?          @db.VarChar(96)
  stage           String?          @db.VarChar(96)
  unitNo          Int?             @map("unit_no")
  name            String           @db.VarChar(160)
  defaultHours    Decimal          @default(1) @map("default_hours") @db.Decimal(8, 2)
  teachingContent String?          @map("teaching_content") @db.Text
  status          CourseUnitStatus @default(ACTIVE)
  createdBy       String?          @map("created_by") @db.Uuid
  updatedBy       String?          @map("updated_by") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  course         Course?             @relation(fields: [courseId], references: [id])
  lessonType     LessonType          @relation(fields: [lessonTypeId], references: [id])
  scheduleRules  ClassScheduleRule[]
  lessonSessions LessonSession[]

  @@index([courseId, status])
  @@index([lessonTypeId, status])
  @@index([category, stage, unitNo])
  @@map("course_unit_templates")
}

model ClassScheduleRule {
  id             String             @id @default(uuid()) @db.Uuid
  classId        String             @map("class_id") @db.Uuid
  teacherId      String?            @map("teacher_id") @db.Uuid
  lessonTypeId   String             @map("lesson_type_id") @db.Uuid
  unitTemplateId String?            @map("unit_template_id") @db.Uuid
  weekday        Int
  startMinute    Int                @map("start_minute")
  endMinute      Int                @map("end_minute")
  effectiveFrom  DateTime           @map("effective_from") @db.Date
  effectiveTo    DateTime?          @map("effective_to") @db.Date
  timezone       String             @default("Asia/Shanghai") @db.VarChar(64)
  lessonHours    Decimal            @default(1) @map("lesson_hours") @db.Decimal(8, 2)
  classroom      String?            @db.VarChar(128)
  status         ScheduleRuleStatus @default(ACTIVE)
  createdBy      String?            @map("created_by") @db.Uuid
  updatedBy      String?            @map("updated_by") @db.Uuid
