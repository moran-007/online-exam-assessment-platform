{
  "name": "online-exam-assessment-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Online exam and intelligent assessment platform backend.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "pnpm permissions:check && nest build",
    "dev": "nest start --watch",
    "frontend:dev": "pnpm --dir frontend dev",
    "frontend:build": "pnpm --dir frontend build",
    "frontend:typecheck": "pnpm --dir frontend typecheck",
    "build:all": "pnpm build && pnpm frontend:build",
    "bundle:check": "node scripts/check-bundle-budget.cjs",
    "architecture:check": "node scripts/check-architecture.cjs",
    "security:audit": "pnpm audit --prod --audit-level high --registry=https://registry.npmjs.org",
    "licenses:check": "node scripts/check-dependency-licenses.cjs",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "permissions:sync": "tsx scripts/sync-permissions.ts",
    "permissions:check": "tsx scripts/check-permission-catalog.ts",
    "db:reseed-curriculum": "tsx prisma/reseed-curriculum.ts",
    "db:baseline": "tsx scripts/db-performance-baseline.ts",
    "assets:migrate": "tsx scripts/migrate-legacy-assets.ts",
    "credentials:migrate": "tsx scripts/migrate-hydro-credentials.ts",
    "credentials:verify": "tsx scripts/verify-encrypted-credentials.ts",
    "credentials:verify:hydro": "tsx scripts/migrate-hydro-credentials.ts --verify",
    "openapi:document": "pnpm build && node dist/openapi/generate-openapi.js",
    "openapi:client": "orval --config orval.config.ts",
    "openapi:generate": "pnpm openapi:document && pnpm openapi:client",
    "openapi:check": "pnpm openapi:generate && git diff --exit-code -- docs/openapi.json frontend/src/api/generated",
    "ai:golden:generate": "tsx scripts/generate-ai-golden-samples.ts",
    "migration:worker:profiles": "tsx scripts/rehearse-worker-profiles.ts",
    "migration:worker:operations": "tsx scripts/migrate-worker-academic-operations.ts",
    "migration:worker:lesson-records": "tsx scripts/migrate-worker-lesson-records.ts",
    "migration:worker:scratch": "tsx scripts/migrate-worker-scratch.ts",
    "cutover:worker": "tsx scripts/worker-cutover.ts",
    "fixture:stage6-browser": "tsx scripts/prepare-stage6-browser-fixture.ts",
    "backup:create": "tsx scripts/backup.ts create",
    "backup:verify": "tsx scripts/backup.ts verify",
    "backup:restore": "tsx scripts/backup.ts restore",
    "lint": "eslint .",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "jest --selectProjects unit --runInBand",
    "test:coverage": "jest --config jest.coverage.config.cjs --runInBand",
    "test:db:prepare": "tsx scripts/prepare-test-db.ts",
    "test:integration": "pnpm test:db:prepare && jest --selectProjects integration --runInBand",
    "test:e2e": "pnpm test:db:prepare && playwright test",
    "test:ci": "pnpm lint && pnpm architecture:check && pnpm security:audit && pnpm licenses:check && pnpm openapi:check && pnpm frontend:typecheck && pnpm build:all && pnpm bundle:check && pnpm test:coverage && pnpm test && pnpm test:e2e"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "ajv": "8.20.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.1",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@playwright/test": "^1.61.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "orval": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.6",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  }
}
